{
  "name": "image-metadata-inspector",
  "displayName": "Image Metadata Inspector",
  "description": "Inspect and display metadata of JPG, PNG, and WebP images. Perfect for ComfyUI workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gerkinfeltser/image-metadata-display.git"
  },
  "version": "0.2.0",
  "publisher": "Gerkinfeltser",
  "icon": "images/image_metadata_viewer_icon.png",
  "license": "MIT",
  "keywords": [
    "metadata",
    "exif",
    "image",
    "comfyui",
    "workflow",
    "png",
    "jpg",
    "webp",
    "jpeg"
  ],
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.inspectImageMetadata",
        "title": "Inspect Image Metadata"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .jpg || resourceExtname == .png || resourceExtname == .webp || resourceExtname == .jpeg",
          "command": "extension.inspectImageMetadata",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "extension.inspectImageMetadata"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceExtname == .jpg || resourceExtname == .png || resourceExtname == .webp || resourceExtname == .jpeg",
          "command": "extension.inspectImageMetadata",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./node_modules/vscode-test/out/runTest.js",
    "build": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.87.2",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "exiftool-vendored": "^35.19.0",
    "jws": "^3.2.3"
  },
  "optionalDependencies": {
    "exiftool-vendored.exe": "^13.53.0",
    "exiftool-vendored.pl": "^13.53.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.6",
    "undici": "7.28.0",
    "js-yaml": "4.2.0"
  }
}
